# Private key of the EOA used to sign Polymarket orders (do NOT commit real keys)
PRIVATE_KEY=0xyourPrivateKeyHere

# Optional: address of the funder (proxy/safe) wallet that holds USDC.
# Leave unset to use the signer address.
# FUNDER_ADDRESS=0x...

# Optional: Polymarket CLOB host (defaults to https://clob.polymarket.com)
# CLOB_HOST=https://clob.polymarket.com

# Optional: Polygon chain id (137 = mainnet, 80002 = amoy)
# CHAIN_ID=137
